[
  {
    "id": "RBI_CRR_DAILY",
    "name": "Daily Cash Reserve Ratio",
    "domain": "core_banking",
    "jurisdiction": "IN",
    "reporting_frequency": "daily",
    "required_sources": ["core_banking_accounts", "core_banking_transactions"],
    "required_metrics": [
      {
        "metric_id": "total_demand_liabilities",
        "description": "Total demand deposit balances at end of reporting period.",
        "source": "core_banking_accounts",
        "field_mapping": {
          "account_id": "account_id",
          "balance_amount": "current_balance",
          "currency": "currency",
          "liability_type": "account_type"
        }
      },
      {
        "metric_id": "large_cash_withdrawals",
        "description": "Cash withdrawals above the internal threshold.",
        "source": "core_banking_transactions",
        "field_mapping": {
          "transaction_id": "transaction_id",
          "account_id": "account_id",
          "amount": "amount",
          "transaction_channel": "channel",
          "transaction_date": "posted_at"
        }
      }
    ]
  },
  {
    "id": "AML_SUSPICIOUS_ACTIVITY",
